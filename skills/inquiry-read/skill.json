{
  "name": "inquiry-read",
  "description": "Read inquiries from Tradew platform.",
  "version": "1.0.0",
  "input": {
    "type": "object",
    "properties": {
      "language": {
        "type": "string",
        "description": "Optional. If provided, must be selected by user from LanguagesGet after confirmation. No auto-selection or system inference is allowed."
      },
      "current_page": {
        "type": "number",
        "default": 1
      },
      "page_size": {
        "type": "number",
        "default": 10,
        "minimum": 10,
        "maximum": 50
      },
      "fields": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string"
        }
      }
    }
  },
  "dependencies": {
    "language": {
      "skill": "LanguagesGet",
      "field": "list[].language",
      "mode": "select"
    }
  }
}