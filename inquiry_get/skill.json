{
  "schema_version": "v1",
  "name": "inquiry_get",
  "description": "Get inquiry list from open.tradew.com",
  "author": "MU",
  "version": "1.0.0",
  "functions": [
    {
      "name": "get_inquiry",
      "description": "Fetch inquiry list with pagination",
      "arguments": {
        "type": "object",
        "properties": {
          "current_page": { "type": "number" },
          "page_size": {
            "type": "number",
            "minimum": 100,
            "maximum": 1000
          }
        },
        "required": [ "current_page", "page_size" ]
      }
    }
  ]
}